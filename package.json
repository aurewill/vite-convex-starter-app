    "@mantine/modals": "9.1.0",
    "@mantine/spotlight": "9.1.0",
    "@phosphor-icons/react": "2.1.10",
    "@tanstack/react-router": "1.168.24",
    "clsx": "^2.1.1",
    "convex": "1.36.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "2.0.0",
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/router-plugin": "1.167.27",
    "@types/node": "24.11.1",
